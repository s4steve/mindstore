# Database
POSTGRES_DB=mindstore
POSTGRES_USER=mindstore
POSTGRES_PASSWORD=change_me_strong_password

# API key for service-to-service authentication (MCP server → ingestion)
API_KEY=change_me_strong_api_key

# Bearer token for incoming MCP client connections (distinct from API_KEY which is for internal service auth)
MCP_AUTH_TOKEN=change_me_strong_mcp_token

# Web UI credentials (required — HTTP Basic Auth)
WEB_USERNAME=admin
WEB_PASSWORD=change_me_strong_password

WEBAPP_PORT=3000

# Ingestion service
INGESTION_HOST=0.0.0.0
INGESTION_PORT=8000

# MCP server
MCP_HOST=0.0.0.0
MCP_PORT=8001

# Embedding model (swap to 'voyage' later without restructuring)
EMBEDDER_BACKEND=local
EMBEDDER_MODEL=all-MiniLM-L6-v2

# TLS certificates for the web UI (required — nginx serves HTTPS only)
TLS_CERT_PATH=/path/to/server.crt
TLS_KEY_PATH=/path/to/server.key

# Optional: Voyage AI (for future integration)
# VOYAGE_API_KEY=
