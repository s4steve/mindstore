# Database
POSTGRES_DB=mindstore
POSTGRES_USER=mindstore
POSTGRES_PASSWORD=change_me_strong_password

# API key for service-to-service authentication (MCP server → ingestion)
API_KEY=change_me_strong_api_key

# HMAC secret for signing web UI session cookies. Must be distinct from
# API_KEY so that a leaked REST key cannot be used to forge sessions.
# Rotating this value logs everyone out (no revocation list otherwise).
SESSION_SECRET=change_me_strong_session_secret

# Bearer token for incoming MCP client connections (distinct from API_KEY which is for internal service auth)
MCP_AUTH_TOKEN=change_me_strong_mcp_token

# Web UI credentials (required — HTTP Basic Auth)
WEB_USERNAME=admin
WEB_PASSWORD=change_me_strong_password

WEBAPP_PORT=3000

# Ingestion service
INGESTION_HOST=0.0.0.0
INGESTION_PORT=8000

# MCP server
MCP_HOST=0.0.0.0
MCP_PORT=8001

# Embedding model (swap to 'voyage' later without restructuring)
EMBEDDER_BACKEND=local
EMBEDDER_MODEL=all-MiniLM-L6-v2

# AI cleanup ("refine" on the Capture page). The refiner rewrites raw thoughts
# before they are saved. Leave ANTHROPIC_API_KEY empty to disable refine — the
# /refine endpoint then returns 503 and capture still works as-is.
# Note: when used, raw thought text is sent to Anthropic. Embeddings and storage
# remain local. A local backend can be added later behind REFINER_BACKEND.
REFINER_BACKEND=anthropic
REFINER_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# TLS certificates for the web UI (required — nginx serves HTTPS only)
TLS_CERT_PATH=/path/to/server.crt
TLS_KEY_PATH=/path/to/server.key

# Optional: Voyage AI (for future integration)
# VOYAGE_API_KEY=
